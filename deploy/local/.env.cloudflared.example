# Copy this file to .env.cloudflared and fill in both values.
# .env.cloudflared is gitignored — never commit it.

# Tunnel token from the Cloudflare Zero Trust dashboard:
#   Networks → Tunnels → your tunnel → Overview → "Install connector"
#   Copy the token from the Docker command shown there.
TUNNEL_TOKEN=<paste-token-here>

# Your public domain (e.g. cogito.example.com).
# Must match BOTH:
#   1. The public hostname configured in the Cloudflare tunnel routing
#      (point the service URL to https://cogito-caddy:443, enable noTLSVerify).
#   2. One of the origins in ALLOWED_ORIGINS in the root .env file.
COGITO_PUBLIC_DOMAIN=cogito.example.com
